# EmberSight environment variables

# --- LLMs ---
ANTHROPIC_API_KEY=
# Optional, used by some langchain helpers
OPENAI_API_KEY=

# --- External data sources ---
# NASA FIRMS map key (free) - https://firms.modaps.eosdis.nasa.gov/api/area/
FIRMS_MAP_KEY=
# SynopticPy token (free) - https://developers.synopticdata.com/
SYNOPTIC_TOKEN=
# Optional Mapbox token; if unset, frontend falls back to CARTO Dark via MapLibre
MAPBOX_TOKEN=

# --- Required by NWS API ---
NWS_USER_AGENT=EmberSight Hackathon (contact@example.com)

# --- Service wiring ---
# Frontend uses this to reach FastAPI
AGENT_BASE_URL=http://localhost:8000
# LangGraph persistence
EMBERSIGHT_CHECKPOINT_DB=/tmp/embersight.db

# --- Per-node model overrides (optional) ---
EMBERSIGHT_MODEL_MASTER_IC=anthropic:claude-sonnet-4-5
EMBERSIGHT_MODEL_SPREAD=anthropic:claude-sonnet-4-5
EMBERSIGHT_MODEL_DEFAULT=anthropic:claude-haiku-4-5
